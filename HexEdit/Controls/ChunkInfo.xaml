<UserControl
	x:Class="HexEdit.Controls.ChunkInfo"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:HexEdit.Controls"
	d:Background="White"
	d:DesignHeight="200"
	d:DesignWidth="200"
	mc:Ignorable="d">
	<Border >
		<StackPanel Margin="5">
			<TextBlock   Text="Chunk Info" FontWeight="Bold" />
			<TextBlock   Text="{Binding SelectedChunk.Type}"  />
			<TextBlock   Text="{Binding SelectedChunk.Description}"  />
			<TextBlock   Text="{Binding SelectedChunk.UnicodeCharacter}"  />
		</StackPanel>
	</Border>
</UserControl>
